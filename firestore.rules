rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Testimonies - Fully Public
    match /testimonies/{testimonyId} {
      allow read: if true;                    // Anyone can read
      allow create: if true;                  // Anyone can publish (Public Live)
      allow update, delete: if false;         // No one can edit/delete (prevents abuse)
    }

    // Users (keep if you plan to add auth later)
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // MENU (keep your existing)
    match /MENU/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
