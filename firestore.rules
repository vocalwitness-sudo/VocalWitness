rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for readability
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isSteward() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSteward == true;
    }

    // Allow public read for MENU
    match /MENU/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Users: Public can read profile info, but only owner updates
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }

    // Testimonies: Secure moderation and deletion
    match /testimonies/{testimonyId} {
      // Prevent reading if marked as removed by moderator
      allow read: if resource.data.moderationStatus != "removed";
      allow create: if isSignedIn();
      
      // Allow delete by author, or by a Steward for moderation
      allow delete: if isOwner(resource.data.authorId) || isSteward();
      
      // Allow updates only if changing moderation status (Steward only) 
      // or if owner is updating own content
      allow update: if (isOwner(resource.data.authorId)) || 
                       (isSteward() && request.resource.data.moderationStatus != resource.data.moderationStatus);
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.members.hasAny([request.auth.uid]) || resource.data.createdBy == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
