rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts Collection (Matches composer.js & feed.js)
    match /posts/{postId} {
      allow read: if true;
      
      // User must be authenticated and setting their own authorId
      allow create: if request.auth != null 
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.content.size() <= 5000;

      // Allow updates only for liking/commenting counters (or prevent editing post content)
      allow update: if request.auth != null 
                    && request.resource.data.authorId == resource.data.authorId;

      allow delete: if false; // Immutability
    }

    // Legacy Testimonies match (kept for backwards compatibility)
    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // MENU / Config
    match /MENU/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
