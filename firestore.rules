rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Testimonies (Immutable + Author Validation)
    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.author.uid == request.auth.uid
                    && request.resource.data.content.size() <= 5000; // Cap text length
      allow update, delete: if false; // Strict Immutability
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // MENU / Config
    match /MENU/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
