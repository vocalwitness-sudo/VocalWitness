rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Testimonies (Ledger)
    match /testimonies/{testimonyId} {
      allow read: if true;                    // Public read
      allow create: if request.auth != null 
                   && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null 
                            && request.auth.uid == resource.data.authorId;
    }

    // Posts (if used)
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && request.auth.uid == resource.data.authorId;
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // 👉 ADD THIS NEW BLOCK FOR GROUPS
    match /groups/{groupId} {
      allow read: if true;                                    // Anyone can view the group list
      allow create: if request.auth != null;                  // Authenticated users can create groups
      allow update: if request.auth != null;                  // Authenticated users can join/update member lists
    }
  }
}
