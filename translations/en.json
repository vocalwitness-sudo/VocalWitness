export async function loadTranslations(langCode = 'en') {
    try {
        const isSupported = supportedLanguages.some(l => l.code === langCode);
        if (!isSupported) langCode = 'en';

        // Try multiple possible paths
        let url = `translations/${langCode}.json`;
        
        const response = await fetch(url);
        
        if (response.ok) {
            currentTranslations = await response.json();
            console.log(`✅ Loaded ${langCode} translations successfully`);
        } else {
            console.warn(`⚠️ ${langCode}.json not found, using English fallback`);
            // Try absolute path as fallback
            const fallbackResponse = await fetch(`/translations/${langCode}.json`);
            if (fallbackResponse.ok) {
                currentTranslations = await fallbackResponse.json();
                console.log(`✅ Loaded ${langCode} with fallback path`);
            } else {
                currentTranslations = {};
            }
        }
    } catch (e) {
        console.warn(`Failed to load ${langCode}`, e);
        currentTranslations = {};
        
        // Emergency English fallback
        if (langCode === 'en') {
            console.log("Using hardcoded English fallback");
            currentTranslations = {
                placeholder: "What truth do you wish to share today...",
                postButton: "Publish to the Square",
                photoForensic: "📸 Forensic Photo",
                voiceTestimony: "🎤 Voice Testimony"
            };
        }
    }

    currentLang = langCode;
    localStorage.setItem('preferredLang', langCode);
    applyTranslations();
    applyTextDirection(langCode);
}
