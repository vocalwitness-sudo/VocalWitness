export async function loadTranslations(langCode = 'en') {
    try {
        const isSupported = supportedLanguages.some(l => l.code === langCode);
        if (!isSupported) langCode = 'en';

        console.log(`🔄 Trying to load translations/${langCode}.json`);

        const paths = [
            `translations/${langCode}.json`,
            `/translations/${langCode}.json`,
            `./translations/${langCode}.json`
        ];

        let loaded = false;
        for (let url of paths) {
            try {
                const response = await fetch(url, { cache: 'no-cache' });
                if (response.ok) {
                    currentTranslations = await response.json();
                    console.log(`✅ Successfully loaded ${langCode} from: ${url}`);
                    loaded = true;
                    break;
                }
            } catch (err) {
                console.log(`Failed path: ${url}`);
            }
        }

        if (!loaded) {
            console.warn(`⚠️ Could not load ${langCode}.json - using empty fallback`);
            currentTranslations = {};
        }
    } catch (e) {
        console.error(`Failed to load ${langCode}`, e);
        currentTranslations = {};
    }

    currentLang = langCode;
    localStorage.setItem('preferredLang', langCode);
    applyTranslations();
    applyTextDirection(langCode);
}
