{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      ".git/**",
      "tailwind.config.js",
      "postcss.config.js"
    ],
    "rewrites": [
      {
        "source": "/verify",
        "destination": "/verify.html"
      },
      {
        "source": "/citizen-talk",
        "destination": "/citizen-talk.html"
      },
      {
        "source": "/true-witness",
        "destination": "/true-witness.html"
      },
      {
        "source": "/live-arena",
        "destination": "/live-arena.html"
      },
      {
        "source": "/privacy",
        "destination": "/privacy.html"
      },
      {
        "source": "/terms",
        "destination": "/terms.html"
      },
      {
        "source": "/safety",
        "destination": "/safety.html"
      },
      {
        "source": "/about",
        "destination": "/about.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|ico|svg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://*.firebaseio.com https://*.googleapis.com https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://checkout.flutterwave.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; img-src 'self' data: https:; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com wss://*.firebaseio.com; frame-src 'self' https://checkout-v3.flutterwave.com https://*.flutterwave.com;"
          }
        ]
      }
    ]
  }
}
