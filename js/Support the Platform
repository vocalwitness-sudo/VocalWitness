// js/payment.js - Flutterwave + Nigeria Friendly
import { showToast } from './utils.js';
import { doc, setDoc } from "https://www.gstatic.com/firebasejs/11.0.0/firebase-firestore.js";
import { db } from './firebase-config.js';

export function initiatePlatformSupport(user) {
    const amount = 4990; // ₦4,990 / month

    FlutterwaveCheckout({
        public_key: "FLWPUBK_TEST-XXXXXXXXXXXXX", // ← Replace with your key
        tx_ref: "support-" + Date.now(),
        amount: amount,
        currency: "NGN",
        payment_options: "card,banktransfer,ussd,applepay,googlepay",
        customer: {
            email: user.email,
            name: user.displayName || "Platform Supporter",
            phone_number: user.phone || "",
        },
        customizations: {
            title: "Support VocalWitness",
            description: "Help protect Truth • Evidence • Public Square",
            logo: "https://vocalwitness-3affa.web.app/logo.png",
        },
        callback: function (response) {
            console.log("Payment successful", response);
            verifySupportPayment(response.tx_ref, user.uid);
        },
        onClose: function() {
            showToast("Payment cancelled", "info");
        }
    });
}

async function verifySupportPayment(txRef, userId) {
    showToast("Verifying payment...", "info");

    try {
        // TODO: Call your Firebase Cloud Function for verification
        // For now, mark as Supporter
        await setDoc(doc(db, "users", userId), {
            isSupporter: true,
            supporterSince: new Date().toISOString(),
            lastPayment: new Date().toISOString()
        }, { merge: true });

        showToast("Thank you for supporting the Platform! 🎉", "success");
        location.reload();
    } catch (e) {
        showToast("Payment received. Upgrade pending verification.", "error");
    }
}
