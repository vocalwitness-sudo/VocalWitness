// js/support.js - Support & Crypto Contribution Workflow
import { showToast } from './utils.js';

export function initSupportModal() {
    const supportTrigger = document.querySelector('[data-action="support-square"], .support-square-btn, #supportSquareBtn');
    
    // Build or hook into the existing modal
    const modalHtml = `
        <div id="supportModal" class="fixed inset-0 bg-black/80 backdrop-blur-md z-50 flex items-center justify-center p-4 hidden">
            <div class="glass max-w-md w-full rounded-3xl p-6 border border-emerald-500/30 text-white relative">
                <button id="closeSupportModal" class="absolute top-4 right-4 text-zinc-400 hover:text-white text-xl">✕</button>
                
                <div class="text-center mb-6">
                    <div class="w-12 h-12 bg-emerald-500/20 rounded-2xl flex items-center justify-center mx-auto mb-3 text-2xl">🛡️</div>
                    <h3 class="text-xl font-bold text-white">Sustain the Public Square</h3>
                    <p class="text-xs text-emerald-300 mt-1">VocalWitness stays free and un-manipulated through voluntary community backing.</p>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-zinc-400 mb-2">Select Contribution Amount (USD)</label>
                        <div class="grid grid-cols-3 gap-2">
                            <button type="button" class="support-tier-btn py-2 bg-zinc-800 hover:bg-emerald-600/30 border border-zinc-700 rounded-xl text-sm font-medium transition-all" data-amount="5">$5</button>
                            <button type="button" class="support-tier-btn py-2 bg-zinc-800 hover:bg-emerald-600/30 border border-zinc-700 rounded-xl text-sm font-medium transition-all" data-amount="15">$15</button>
                            <button type="button" class="support-tier-btn py-2 bg-zinc-800 hover:bg-emerald-600/30 border border-zinc-700 rounded-xl text-sm font-medium transition-all" data-amount="50">$50</button>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">Custom Amount ($ USD)</label>
                        <input type="number" id="customSupportAmount" placeholder="Enter amount" min="1" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-emerald-500" value="10">
                    </div>

                    <button id="proceedCryptoBtn" class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 rounded-xl font-medium text-sm transition-all shadow-lg shadow-emerald-600/20">
                        Proceed with Crypto (NOWPayments) ⚡
                    </button>
                </div>

                <p class="text-[10px] text-zinc-500 text-center mt-4">Powered by non-custodial crypto rails. No tracking, no intrusive data collection.</p>
            </div>
        </div>
    `;

    // Append modal to body if not already present
    if (!document.getElementById('supportModal')) {
        document.body.insertAdjacentHTML('beforeend', modalHtml);
    }

    const modal = document.getElementById('supportModal');
    const closeBtn = document.getElementById('closeSupportModal');
    const proceedBtn = document.getElementById('proceedCryptoBtn');

    // Toggle Modal Visibility via global triggers or button hooks
    document.addEventListener('click', (e) => {
        if (e.target.closest('#supportTheSquareBtn') || e.target.closest('.support-trigger')) {
            modal.classList.remove('hidden');
        }
    });

    closeBtn?.addEventListener('click', () => modal.classList.add('hidden'));
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.add('hidden');
    });

    // Tier button selectors
    document.querySelectorAll('.support-tier-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            document.querySelectorAll('.support-tier-btn').forEach(b => b.classList.remove('border-emerald-500', 'bg-emerald-600/20'));
            e.target.classList.add('border-emerald-500', 'bg-emerald-600/20');
            document.getElementById('customSupportAmount').value = e.target.getAttribute('data-amount');
        });
    });

    // Handle NOWPayments Redirect / Invoice Generation Trigger
    proceedBtn?.addEventListener('click', () => {
        const amount = document.getElementById('customSupportAmount').value || 10;
        
        // You can link directly to your NOWPayments donation link or invoke their API invoice generation URL here:
        // Example: const NOWPAYMENTS_DONATION_URL = "https://nowpayments.io/donation/?api_key=YOUR_API_KEY";
        // Or construct a dynamic invoice redirect
        showToast(`Preparing $${amount} secure crypto invoice...`, "info");
        
        // Placeholder redirect behavior to NOWPayments gateway/widget
        setTimeout(() => {
            window.open(`https://nowpayments.io/payment?price_amount=${amount}&price_currency=usd`, '_blank');
            modal.classList.add('hidden');
        }, 1000);
    });
}
